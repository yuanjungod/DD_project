# Copy to .env at the repository root and adjust for your environment.
# Both backend and agent_service read this file.

# --- Shared ---
DD_DATA_ROOT=.dd_project/data

# --- Backend (port 8010) ---
# DATABASE_URL=sqlite:///./.dd_project/data/platform/dd_platform.db
# DATABASE_URL=postgresql+psycopg2://dd:dd@localhost:5432/dd_platform
AGENT_SERVICE_URL=http://127.0.0.1:8011
AGENT_CALLBACK_SECRET=local-dd-agent-callback
AGENT_API_KEY=local-dd-agent-api-key
AUTH_SECRET_KEY=dev-secret-change-me
# ENV=production
DD_SEED_DEFAULT_USERS=true
# DD_DEFAULT_USERS_CONFIG=catalog/default_users.yaml

# --- Agent service (port 8011) ---
PLATFORM_CALLBACK_BASE_URL=http://127.0.0.1:8010
AGENT_CALLBACK_SECRET=local-dd-agent-callback
AGENT_API_KEY=local-dd-agent-api-key
# DD_MODEL_BASE_URL=http://127.0.0.1:8080/v1
# DD_MODEL_API_KEY=
DD_SESSION_HISTORY_ENABLED=true

# --- Frontend (Vite, port 5173) ---
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8010
# VITE_API_BASE_URL=http://127.0.0.1:8010
# VITE_DEFAULT_LOGIN_EMAIL=admin@example.com
# VITE_DEFAULT_LOGIN_PASSWORD=admin123
# VITE_SHOW_DEV_LOGIN_HINTS=true