{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dd-platform.local/schemas/agent_result.schema.json",
  "title": "AgentResult",
  "type": "object",
  "required": ["agent", "status", "summary", "findings"],
  "properties": {
    "agent": { "type": "string" },
    "status": { "type": "string", "enum": ["pending", "running", "completed", "failed", "paused"] },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "description", "risk_level", "confidence"],
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "risk_level": { "type": "string", "enum": ["low", "medium", "high", "unknown"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "output_dir": { "type": "string" },
    "output_readme_path": { "type": "string" }
  }
}
