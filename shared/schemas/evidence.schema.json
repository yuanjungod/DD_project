{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dd-platform.local/schemas/evidence.schema.json",
  "title": "Evidence",
  "type": "object",
  "required": ["id", "title", "source_type", "excerpt", "confidence", "collected_by"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "source_type": { "type": "string", "enum": ["web", "file", "database", "manual", "mock"] },
    "source_url": { "type": "string" },
    "file_id": { "type": "string" },
    "excerpt": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "collected_by": { "type": "string" },
    "metadata": { "type": "object", "additionalProperties": true }
  }
}
