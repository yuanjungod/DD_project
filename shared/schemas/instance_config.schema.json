{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harness-platform.local/schemas/instance_config.schema.json",
  "title": "InstanceConfig",
  "type": "object",
  "required": ["workflow_template_id", "resources"],
  "properties": {
    "workflow_template_id": {
      "type": "string",
      "description": "Published workflow template id used by downstream runs."
    },
    "workflow_template_version": {
      "type": "integer",
      "description": "Published workflow template version selected for this engagement."
    },
    "resources": {
      "type": "object",
      "properties": {
        "uploaded_files": { "type": "array", "items": { "type": "string" }, "default": [] },
        "trusted_sources": { "type": "array", "items": { "type": "string" }, "default": [] },
        "blocked_sources": { "type": "array", "items": { "type": "string" }, "default": [] },
        "competitors": { "type": "array", "items": { "type": "string" }, "default": [] },
        "metrics": { "type": "array", "items": { "type": "object" }, "default": [] },
        "external_clues": { "type": "array", "items": { "type": "object" }, "default": [] },
        "agent_resource_scopes": { "type": "array", "items": { "type": "object" }, "default": [] }
      }
    },
    "extensions": {
      "type": "object",
      "properties": {
        "subject": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "aliases": { "type": "array", "items": { "type": "string" }, "default": [] },
            "kind": { "type": "string" }
          }
        },
        "workflow_task": {
          "type": "object",
          "required": ["description"],
          "properties": {
            "description": { "type": "string", "minLength": 1 },
            "task": { "type": "string" },
            "goal": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    }
  }
}
